# ── Vercel environment variables ─────────────────────────────────────────────
#
# Copy this file to .env.local for local overrides (already gitignored).
# In Vercel: set these under Project → Settings → Environment Variables.
#
# Required in production:
VITE_API_URL=https://football-sim.fly.dev

# In local dev this is omitted — Vite proxies /auth, /league, /leagues,
# /my-leagues to localhost:3000 automatically via vite.config.ts.
